# API Key - Get from your AI provider
# For Zhipu GLM: https://open.bigmodel.cn/
# For Minimax: https://platform.minimax.pro/
# For OpenAI: https://platform.openai.com/
API_KEY=your_api_key_here

# Model name
# glm-4, glm-4-plus, minimax, gpt-4o, etc.
MODEL_NAME=glm-4

# Base URL (OpenAI compatible endpoint)
# For Zhipu: https://open.bigmodel.cn/api/paas/v4
# For Minimax: https://api.minimax.chat/v1/text/chatcompletion_pro
# For OpenAI: https://api.openai.com/v1
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Database configuration
# DATABASE_PROVIDER can be: sqlite, postgresql, mysql
# Default: sqlite
# DATABASE_PROVIDER=postgresql

# Database URL for Prisma
# SQLite: file:./prisma/dev.db
# PostgreSQL: postgresql://username:password@localhost:5432/library_db?schema=public
# MySQL: mysql://username:password@localhost:3306/library_db
DATABASE_URL="file:./prisma/dev.db"

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Server port
PORT=3001

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173
