<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 192 192" width="192" height="192">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#2563eb"/>
      <stop offset="100%" style="stop-color:#7c3aed"/>
    </linearGradient>
  </defs>
  <rect width="192" height="192" rx="40" fill="url(#bg)"/>
  <!-- Book -->
  <g transform="translate(48, 40)">
    <rect x="0" y="8" width="96" height="80" rx="4" fill="white" opacity="0.95"/>
    <rect x="44" y="0" width="8" height="96" rx="2" fill="#ddd"/>
    <rect x="12" y="20" width="28" height="4" rx="2" fill="#2563eb"/>
    <rect x="12" y="30" width="20" height="3" rx="1.5" fill="#93c5fd"/>
    <rect x="12" y="38" width="24" height="3" rx="1.5" fill="#93c5fd"/>
    <rect x="56" y="20" width="28" height="4" rx="2" fill="#7c3aed"/>
    <rect x="56" y="30" width="20" height="3" rx="1.5" fill="#c4b5fd"/>
    <rect x="56" y="38" width="24" height="3" rx="1.5" fill="#c4b5fd"/>
    <!-- AI sparkle -->
    <circle cx="72" cy="60" r="12" fill="#fbbf24" opacity="0.9"/>
    <text x="72" y="65" text-anchor="middle" font-size="14" font-weight="bold" fill="white">AI</text>
  </g>
</svg>
